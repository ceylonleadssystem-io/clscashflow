rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return signedIn()
        && (
          request.auth.token.email == 'devteam@ceylonrylabs.io'
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userDoc(request.auth.uid).data.adminAccess == true
          )
        );
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isOwner(ownerUid) {
      return signedIn() && request.auth.uid == ownerUid;
    }

    function isTeamMember(ownerUid) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.ownerUid == ownerUid
        && userDoc(request.auth.uid).data.role != 'removed';
    }

    function isOwnerOrTeam(ownerUid) {
      return isOwner(ownerUid) || isTeamMember(ownerUid);
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow get: if signedIn()
        && (
          isPlatformAdmin()
          ||
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || isOwnerOrTeam(uid)
        );
      allow list: if signedIn()
        && (
          isPlatformAdmin()
          ||
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || isOwnerOrTeam(uid)
        );
      allow update: if signedIn()
        && (
          isPlatformAdmin()
          ||
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || request.resource.data.ownerUid == request.auth.uid
        );
      allow delete: if false;

      match /team/{memberOrInviteId} {
        allow get: if isPlatformAdmin() || isOwnerOrTeam(uid) || resource.data.status == 'pending';
        allow list: if isPlatformAdmin() || isOwner(uid);
        allow create: if isPlatformAdmin() || isOwner(uid);
        allow update: if isOwner(uid)
          || isPlatformAdmin()
          || (
            resource.data.status == 'pending'
            && signedIn()
            && request.auth.token.email != null
            && request.auth.token.email == resource.data.email
          );
        allow delete: if isPlatformAdmin() || isOwner(uid);
      }

      match /{subcollection}/{docId} {
        allow read, write: if subcollection != 'team' && (isPlatformAdmin() || isOwnerOrTeam(uid));
      }
    }

    match /invites/{inviteId} {
      allow get: if isPlatformAdmin() || resource.data.status == 'pending' || isOwner(resource.data.ownerUid);
      allow list: if false;
      allow create: if signedIn()
        && (isPlatformAdmin() || request.resource.data.ownerUid == request.auth.uid)
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (
          isPlatformAdmin()
          ||
          isOwner(resource.data.ownerUid)
          || (
            resource.data.status == 'pending'
            && request.auth.token.email != null
            && request.auth.token.email == resource.data.email
          )
        );
      allow delete: if isPlatformAdmin() || isOwner(resource.data.ownerUid);
    }

    match /platformVisits/{visitId} {
      allow read, list, delete: if isPlatformAdmin();
      allow create, update: if false;
    }

    match /supportTickets/{ticketId} {
      allow create: if signedIn();
      allow read, list, update, delete: if isPlatformAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /businessStorySubmissions/{submissionId} {
      allow read, list, update, delete: if isPlatformAdmin();
      allow create: if false;
    }
  }
}
