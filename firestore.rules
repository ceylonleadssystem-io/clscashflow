rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isOwner(ownerUid) {
      return signedIn() && request.auth.uid == ownerUid;
    }

    function isTeamMember(ownerUid) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.ownerUid == ownerUid
        && userDoc(request.auth.uid).data.role != 'removed';
    }

    function isOwnerOrTeam(ownerUid) {
      return isOwner(ownerUid) || isTeamMember(ownerUid);
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow get: if signedIn()
        && (
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || isOwnerOrTeam(uid)
        );
      allow list: if signedIn()
        && (
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || isOwnerOrTeam(uid)
        );
      allow update: if signedIn()
        && (
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || request.resource.data.ownerUid == request.auth.uid
        );
      allow delete: if false;

      match /{subcollection}/{docId} {
        allow read, write: if isOwnerOrTeam(uid);
      }
    }

    match /invites/{inviteId} {
      allow get: if resource.data.status == 'pending' || isOwner(resource.data.ownerUid);
      allow list: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (
          isOwner(resource.data.ownerUid)
          || (
            resource.data.status == 'pending'
            && request.auth.token.email != null
            && request.auth.token.email == resource.data.email
          )
        );
      allow delete: if isOwner(resource.data.ownerUid);
    }
  }
}
