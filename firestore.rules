rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return signedIn()
        && (
          request.auth.token.email == 'devteam@ceylonrylabs.io'
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userDoc(request.auth.uid).data.adminAccess == true
          )
        );
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isOwner(ownerUid) {
      return signedIn() && request.auth.uid == ownerUid;
    }

    function isTeamMember(ownerUid) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.ownerUid == ownerUid
        && userDoc(request.auth.uid).data.role != 'removed';
    }

    function isOwnerOrTeam(ownerUid) {
      return isOwner(ownerUid) || isTeamMember(ownerUid);
    }

    function optionalString(key, max) {
      return !(key in request.resource.data)
        || (request.resource.data[key] is string && request.resource.data[key].size() <= max);
    }

    function optionalBool(key) {
      return !(key in request.resource.data) || request.resource.data[key] is bool;
    }

    function optionalAmount(key) {
      return !(key in request.resource.data)
        || request.resource.data[key] is int
        || request.resource.data[key] is float;
    }

    function optionalTimestampOrString(key) {
      return !(key in request.resource.data)
        || request.resource.data[key] is timestamp
        || request.resource.data[key] is string;
    }

    function validPlatformVisitCreate() {
      return request.resource.data.keys().hasOnly([
          'eventType',
          'visitId',
          'visitorId',
          'sessionId',
          'uid',
          'email',
          'displayName',
          'path',
          'url',
          'title',
          'referrer',
          'timezone',
          'language',
          'userAgent',
          'screen',
          'lastPlan',
          'pageKind',
          'isLanding',
          'isPortal',
          'utcAt',
          'localAt',
          'firstSeenAt',
          'createdAt',
          'source'
        ])
        && request.resource.data.eventType == 'page_view'
        && request.resource.data.source == 'browser-fallback'
        && request.resource.data.visitId is string
        && request.resource.data.visitId.size() <= 140
        && request.resource.data.visitorId is string
        && request.resource.data.visitorId.size() <= 180
        && optionalString('sessionId', 180)
        && optionalString('uid', 140)
        && optionalString('email', 180)
        && optionalString('displayName', 180)
        && optionalString('path', 300)
        && optionalString('url', 900)
        && optionalString('title', 240)
        && optionalString('referrer', 900)
        && optionalString('timezone', 120)
        && optionalString('language', 80)
        && optionalString('userAgent', 500)
        && optionalString('screen', 80)
        && optionalString('lastPlan', 40)
        && optionalString('pageKind', 80)
        && optionalBool('isLanding')
        && optionalBool('isPortal')
        && optionalString('utcAt', 90)
        && optionalString('localAt', 180)
        && optionalString('firstSeenAt', 90)
	        && optionalString('createdAt', 90);
    }

    function isTicketOwner() {
      return signedIn()
        && (
          resource.data.uid == request.auth.uid
          || (
            request.auth.token.email != null
            && resource.data.email == request.auth.token.email
          )
        );
    }

    function validCustomerTicketClose() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt',
          'customerClosedAt',
          'closedBy'
        ])
        && request.resource.data.status == 'closed'
        && request.resource.data.closedBy == 'customer';
    }

    function validPaymentRequestWrite() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'token',
          'uid',
          'ownerUid',
          'name',
          'email',
          'businessName',
          'plan',
          'planName',
          'amount',
          'currency',
          'trialEnd',
          'status',
          'source',
          'page',
          'createdAt',
          'createdAtUtc',
          'updatedAt',
          'updatedAtUtc'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.source == 'trial-expired'
        && request.resource.data.currency == 'LKR'
        && request.resource.data.token is string
        && request.resource.data.token.size() <= 80
        && request.resource.data.plan in ['solo', 'studio', 'business']
        && optionalString('ownerUid', 160)
        && optionalString('name', 180)
        && optionalString('email', 180)
        && optionalString('businessName', 180)
        && optionalString('planName', 80)
        && optionalAmount('amount')
        && optionalString('trialEnd', 90)
        && optionalString('page', 300)
        && optionalTimestampOrString('createdAt')
        && optionalString('createdAtUtc', 90)
        && optionalTimestampOrString('updatedAt')
        && optionalString('updatedAtUtc', 90);
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow get: if signedIn()
        && (
          isPlatformAdmin()
          ||
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || isOwnerOrTeam(uid)
        );
      allow list: if signedIn()
        && (
          isPlatformAdmin()
          ||
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || isOwnerOrTeam(uid)
        );
      allow update: if signedIn()
        && (
          isPlatformAdmin()
          ||
          request.auth.uid == uid
          || resource.data.ownerUid == request.auth.uid
          || request.resource.data.ownerUid == request.auth.uid
        );
      allow delete: if false;

      match /team/{memberOrInviteId} {
        allow get: if isPlatformAdmin() || isOwnerOrTeam(uid) || resource.data.status == 'pending';
        allow list: if isPlatformAdmin() || isOwner(uid);
        allow create: if isPlatformAdmin() || isOwner(uid);
        allow update: if isOwner(uid)
          || isPlatformAdmin()
          || (
            resource.data.status == 'pending'
            && signedIn()
            && request.auth.token.email != null
            && request.auth.token.email == resource.data.email
          );
        allow delete: if isPlatformAdmin() || isOwner(uid);
      }

      match /{subcollection}/{docId} {
        allow read, write: if subcollection != 'team' && (isPlatformAdmin() || isOwnerOrTeam(uid));
      }
    }

    match /invites/{inviteId} {
      allow get: if isPlatformAdmin() || resource.data.status == 'pending' || isOwner(resource.data.ownerUid);
      allow list: if false;
      allow create: if signedIn()
        && (isPlatformAdmin() || request.resource.data.ownerUid == request.auth.uid)
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (
          isPlatformAdmin()
          ||
          isOwner(resource.data.ownerUid)
          || (
            resource.data.status == 'pending'
            && request.auth.token.email != null
            && request.auth.token.email == resource.data.email
          )
        );
      allow delete: if isPlatformAdmin() || isOwner(resource.data.ownerUid);
    }

    match /platformVisits/{visitId} {
      allow read, list, delete: if isPlatformAdmin();
      allow create: if validPlatformVisitCreate();
      allow update: if false;
    }

    match /supportTickets/{ticketId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, list: if isPlatformAdmin() || isTicketOwner();
      allow update: if isPlatformAdmin() || (isTicketOwner() && validCustomerTicketClose());
      allow delete: if isPlatformAdmin();
    }

    match /paymentRequests/{requestId} {
      allow read, list, update, delete: if isPlatformAdmin();
      allow create: if validPaymentRequestWrite();
      allow update: if validPaymentRequestWrite();
    }

    match /businessStorySubmissions/{submissionId} {
      allow read, list, update, delete: if isPlatformAdmin();
      allow create: if false;
    }
  }
}
